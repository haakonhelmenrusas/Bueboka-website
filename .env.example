# Local development (Docker Postgres)
# Start the DB with: docker compose up -d
DATABASE_URL="postgresql://bueboka:bueboka@localhost:5432/bueboka"

# Auth (dev)
BETTER_AUTH_SECRET="change-me"
BETTER_AUTH_URL="http://localhost:3000"

# Email (Resend)
# EMAIL_FROM must be a sender you have verified in Resend, e.g. "Bueboka <noreply@yourdomain.no>"
RESEND_API_KEY=""
EMAIL_FROM=""

# Optional (only needed if you use these integrations locally)
SENTRY_AUTH_TOKEN=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""
