# Database
DATABASE_URL="local-postgres-connection-string"

# Auth (dev)
BETTER_AUTH_SECRET="change-me-to-a-secure-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Physical-device / LAN testing (dev only)
# Set this to your machine's LAN IP so non-OAuth API calls (practices, profile,
# etc.) from a physical Android/iOS device are accepted by the server.
# ⚠️  This does NOT fix Google OAuth on physical devices — see below.
# 1. Find your IP:  ipconfig getifaddr en0   (macOS)
# 2. Start dev server bound to all interfaces:  next dev -H 0.0.0.0
# BETTER_AUTH_URL_MOBILE="http://192.168.x.x:3000"

# Google OAuth on a physical device — requires a public HTTPS URL:
# Private IPs (192.168.x.x) are rejected by Google with
# "device_id and device_name are required for private IP".
# Alternatives:
#   A) Test on iOS Simulator   — can reach the host's localhost:3000 directly.
#   B) Test on Android Emulator — set BETTER_AUTH_URL=http://10.0.2.2:3000
#      (Android's host-machine alias) and register it in Google Console.
#   C) Use a tunnel for physical-device OAuth:
#        npx ngrok http 3000
#        Set BETTER_AUTH_URL=https://<tunnel>.ngrok.io  (restart dev server)
#        Add https://<tunnel>.ngrok.io/api/auth/callback/google
#            → Google Console › Authorised Redirect URIs
#        Add https://<tunnel>.ngrok.io
#            → Google Console › Authorised JavaScript Origins

# Trusted Origins for CORS (comma-separated)
# ⚠️ IMPORTANT: Use different lists for development and production!
#
# Development - Local testing origins (localhost, Expo dev server, local network)
BETTER_AUTH_TRUSTED_ORIGINS_DEV="http://localhost:3000,http://localhost:8081,http://192.168.0.90:3000,exp://,https://appleid.apple.com"
#
# Production - Your production domains ONLY
# ⚠️  Always include bueboka:// — the expo plugin needs it so the post-OAuth
#     redirect appends the session cookie to the deep link. Without it,
#     openAuthSessionAsync closes the browser but the user appears logged out.
# Example: "https://bueboka.no,https://www.bueboka.no,bueboka://"
BETTER_AUTH_TRUSTED_ORIGINS_PROD="bueboka://"

# External Services
# Ballistics calculation service URLs
BALLISTICS_SERVICE_URL="api-url-for-ballistics-calculation"
SIGHTMARKS_CALCULATION_SERVICE_URL="api-url-for-sightmarks-calculation"

# Email (Resend)
# ⚠️ Get your API key from https://resend.com
# EMAIL_FROM must be a sender you have verified in Resend
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# OAuth Providers (Optional)
# ⚠️ Keep these secret! Get from respective provider consoles:
# Google: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Monitoring (Optional)
# ⚠️ Get from https://sentry.io
SENTRY_AUTH_TOKEN=""

# Environment
NODE_ENV="development"

