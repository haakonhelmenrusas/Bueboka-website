# Database
DATABASE_URL="local-postgres-connection-string"

# Auth (dev)
BETTER_AUTH_SECRET="change-me-to-a-secure-random-string"
BETTER_AUTH_URL="http://localhost:3000"

# Trusted Origins for CORS (comma-separated)
# ⚠️ IMPORTANT: Use different lists for development and production!
#
# Development - Local testing origins (localhost, Expo dev server, local network)
BETTER_AUTH_TRUSTED_ORIGINS_DEV="http://localhost:3000,http://localhost:8081,http://192.168.0.90:3000,exp://,https://appleid.apple.com"
#
# Production - Your production domains ONLY
# Example: "https://bueboka.no,https://www.bueboka.no,https://api.bueboka.no,https://appleid.apple.com"
# Note: Always include https://appleid.apple.com for Apple Sign In to work
BETTER_AUTH_TRUSTED_ORIGINS_PROD="https://appleid.apple.com"

# External Services
# Ballistics calculation service URLs
BALLISTICS_SERVICE_URL="api-url-for-ballistics-calculation"
SIGHTMARKS_CALCULATION_SERVICE_URL="api-url-for-sightmarks-calculation"

# Email (Resend)
# ⚠️ Get your API key from https://resend.com
# EMAIL_FROM must be a sender you have verified in Resend
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# OAuth Providers (Optional)
# ⚠️ Keep these secret! Get from respective provider consoles:
# Google: https://console.cloud.google.com/
# Apple: https://developer.apple.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# Monitoring (Optional)
# ⚠️ Get from https://sentry.io
SENTRY_AUTH_TOKEN=""

# Environment
NODE_ENV="development"

